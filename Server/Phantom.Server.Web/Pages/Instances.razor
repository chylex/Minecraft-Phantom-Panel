@page "/instances"
@using Phantom.Common.Data.Instance
@using Phantom.Server.Services.Agents
@using Phantom.Server.Services.Instances
@using System.Collections.Immutable
@implements IDisposable
@inject AgentManager AgentManager
@inject InstanceManager InstanceManager

<h1>Instances</h1>

<a href="/instances/create" class="btn btn-primary" role="button">New Instance</a>

<table class="table align-middle">
  <thead>
    <tr>
      <th style="min-width: 200px;">Name</th>
      <th style="min-width: 200px;">Agent</th>
      <th style="width: 125px;" class="text-center">Port</th>
      <th style="width: 125px;" class="text-end">Memory</th>
      <th style="width: 350px;">Identifier</th>
      <th style="width: 225px;">Status</th>
      <th style="width: 200px;">Actions</th>
    </tr>
  </thead>
  @if (!instances.IsEmpty) {
    <tbody>
      @foreach (var (configuration, status) in instances) {
        var instanceGuid = configuration.InstanceGuid.ToString();
        <tr>
          <td>@configuration.InstanceName</td>
          <td>@(agentNames.TryGetValue(configuration.AgentGuid, out var agentName) ? agentName : string.Empty)</td>
          <td class="text-center">
            <code>@configuration.ServerPort</code>
          </td>
          <td class="text-end">@configuration.MemoryAllocation.InMegabytes MB</td>
          <td>
            <code class="text-uppercase">@instanceGuid</code>
          </td>
          <td>
            @switch (status) {
              case InstanceStatus.Offline:
                <text>Offline</text>
                break;

              case InstanceStatus.Invalid invalid:
                <text>Invalid <sup title="@invalid.Reason">[?]</sup></text>
                break;

              case InstanceStatus.NotRunning:
                <text>Not Running</text>
                break;

              case InstanceStatus.Downloading downloading:
                <text>Downloading Server (@downloading.Progress%)</text>
                break;

              case InstanceStatus.Launching:
                <text>Launching</text>
                break;

              case InstanceStatus.Running:
                <text>Running</text>
                break;

              case InstanceStatus.Stopping:
                <text>Stopping</text>
                break;

              case InstanceStatus.Failed failed:
                <text>Failed <sup title="@failed.Reason.ToSentence()">[?]</sup></text>
                break;
            }
          </td>
          <td>
            <a href="/instances/@instanceGuid" class="btn btn-outline-info btn-sm">Detail</a>
          </td>
        </tr>
      }
    </tbody>
  }
  <tfoot>
    <tr>
      <td colspan="7">
        @if (instances.IsEmpty) {
          <text>No instances.</text>
        }
      </td>
    </tr>
  </tfoot>
</table>

@code {

  private ImmutableArray<Instance> instances = ImmutableArray<Instance>.Empty;
  private ImmutableDictionary<Guid, string> agentNames = ImmutableDictionary<Guid, string>.Empty;

  protected override void OnInitialized() {
    InstanceManager.InstancesChanged.Subscribe(this, instances => {
      this.instances = instances.Values.OrderBy(static instance => instance.Configuration.InstanceName).ToImmutableArray();
      InvokeAsync(StateHasChanged);
    });

    AgentManager.AgentsChanged.Subscribe(this, agents => {
      this.agentNames = agents.ToImmutableDictionary(static agent => agent.Guid, static agent => agent.Name);
      InvokeAsync(StateHasChanged);
    });
  }

  void IDisposable.Dispose() {
    InstanceManager.InstancesChanged.Unsubscribe(this);
    AgentManager.AgentsChanged.Unsubscribe(this);
  }

}
