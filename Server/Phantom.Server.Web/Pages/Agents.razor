@page "/agents"
@using System.Collections.Immutable
@using Phantom.Server.Services.Agents
@using Phantom.Common.Data
@using Phantom.Common.Messages.ToAgent
@implements IDisposable
@inject AgentManager AgentManager
@inject AgentStatsManager AgentStatsManager
@inject AgentAuthToken AgentAuthToken

<h1>Agents</h1>

<table class="table align-middle">
  <thead>
    <tr>
      <th>Name</th>
      <th class="text-end">Instances</th>
      <th class="text-end">Memory</th>
      <th class="text-end">Version</th>
      <th>Identifier</th>
      <th class="text-center">Status</th>
      <th>Actions</th>
    </tr>
  </thead>
  @if (!agents.IsEmpty) {
    <tbody>
      @foreach (var agent in agents) {
        <tr>
          <td>@agent.Name</td>
          @if (agentStats.TryGetValue(agent.Guid, out var stats)) {
            var agentInfo = stats.AgentInfo;
            <td class="text-end">@stats.UsedInstances / @agentInfo.MaxInstances</td>
            <td class="text-end">@stats.UsedMemory.InMegabytes / @agentInfo.MaxMemory.InMegabytes MB</td>
            <td class="text-end">@agentInfo.Version</td>
            <td>
              <code class="text-uppercase">@agent.Guid.ToString()</code>
            </td>
            <td class="text-center text-success">Online</td>
            <td>
              <button type="button" class="btn btn-danger btn-sm" @onclick="() => ShutdownAgent(agent.Guid)" disabled="@GetOrAddAgentRow(agent.Guid).IsShutdownButtonDisabled">Shutdown</button>
            </td>
          }
          else {
            <td class="text-end">-</td>
            <td class="text-end">-</td>
            <td class="text-end">-</td>
            <td>
              <code class="text-uppercase">@agent.Guid.ToString()</code>
            </td>
            <td class="text-center text-danger">Offline</td>
            <td></td>
          }
        </tr>
      }
    </tbody>
  }
  <tfoot>
    <tr>
      <td colspan="7">
        @if (agents.IsEmpty) {
          <text>No agents registered.</text>
        }
        Register agents using the token: <code>@AgentAuthToken</code>
      </td>
    </tr>
  </tfoot>
</table>

@code {

  private ImmutableArray<Agent> agents = ImmutableArray<Agent>.Empty;
  private ImmutableDictionary<Guid, AgentStats> agentStats = ImmutableDictionary<Guid, AgentStats>.Empty;
  private readonly Dictionary<Guid, AgentRow> agentRows = new();

  private sealed class AgentRow {
    public bool IsShutdownButtonDisabled { get; set; } = false;
  }

  protected override void OnInitialized() {
    AgentManager.AgentsChanged.Subscribe(this, agents => {
      this.agents = agents.Sort(static (a1, a2) => a1.Name.CompareTo(a2.Name));

      var remainingGuids = agents.Select(static agent => agent.Guid).ToImmutableHashSet();
      foreach (var guid in agentRows.Keys) {
        if (!remainingGuids.Contains(guid)) {
          agentRows.Remove(guid);
        }
      }

      InvokeAsync(StateHasChanged);
    });

    AgentStatsManager.AgentStatsChanged.Subscribe(this, agentStats => {
      this.agentStats = agentStats.ToImmutableDictionary(static stats => stats.AgentInfo.Guid);
      InvokeAsync(StateHasChanged);
    });
  }

  private AgentRow GetOrAddAgentRow(Guid guid) {
    return agentRows.TryGetValue(guid, out var row) ? row : agentRows[guid] = new AgentRow();
  }

  private async Task ShutdownAgent(Guid guid) {
    GetOrAddAgentRow(guid).IsShutdownButtonDisabled = true;
    await AgentManager.SendMessage(guid, new ShutdownAgentMessage());
  }

  void IDisposable.Dispose() {
    AgentManager.AgentsChanged.Unsubscribe(this);
    AgentStatsManager.AgentStatsChanged.Unsubscribe(this);
  }

}
