@page "/agents"

<h1>Agents</h1>

<table class="table">
  <thead>
    <tr>
      <th>Name</th>
      <th class="text-end">Instances</th>
      <th class="text-end">Memory</th>
      <th>Version</th>
      <th>Identifier</th>
    </tr>
  </thead>
  @if (!agents.IsEmpty) {
    <tbody>
      @foreach (var agent in agents) {
        <tr>
          <td>@agent.Name</td>
          <td class="text-end">? / @agent.MaxInstances</td>
          <td class="text-end">? / @agent.MaxMemory.InMegabytes MB</td>
          <td>@agent.Version</td>
          <td>
            <code class="text-uppercase">@agent.Guid.ToString()</code>
          </td>
        </tr>
      }
    </tbody>
  }
  <tfoot>
    <tr>
      <td colspan="5">
        @(agents.IsEmpty ? "No agents registered." : "")
        Register new agents using the token: <code>@Services.AgentManager.AuthToken</code>
      </td>
    </tr>
  </tfoot>
</table>
@using Phantom.Common.Data
@using Phantom.Server.Services
@using System.Collections.Immutable
@implements IDisposable

@code {

  private ImmutableArray<AgentInfo> agents = ImmutableArray<AgentInfo>.Empty;

  protected override void OnInitialized() {
    Services.AgentManager.AgentInfoChanged.Subscribe(this, agents => {
      this.agents = agents;
      InvokeAsync(StateHasChanged);
    });
  }

  void IDisposable.Dispose() {
    Services.AgentManager.AgentInfoChanged.Unsubscribe(this);
  }

}
