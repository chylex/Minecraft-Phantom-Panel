@typeparam TValue
@inherits FormInputBase<TValue>

<FormLabel Id="@Id" Label="@Label" LabelFragment="@LabelFragment" />

@if (Type == FormNumberInputType.Number) {
  <InputNumber Value="@Value" ValueChanged="@ValueChanged" ValueExpression="@ValueExpression" AdditionalAttributes="@GetAttributes("form-control")" />
}
else if (Type == FormNumberInputType.Range) {
  <InputRange Value="@Value" ValueChanged="@ValueChanged" ValueExpression="@ValueExpression" AdditionalAttributes="@GetAttributes("form-range")" />
}

<ValidationMessage For="@ValueExpression" class="invalid-feedback" />

@code {

  [Parameter]
  public FormNumberInputType Type { get; set; } = FormNumberInputType.Number;

}
